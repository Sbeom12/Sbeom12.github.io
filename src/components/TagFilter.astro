---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---
<div id="tag-filter" class="flex flex-wrap gap-2">
  <button
    data-tag="all"
    class="tag-btn active text-sm px-3 py-1.5 rounded-full border border-(--color-border) dark:border-(--color-dark-border) hover:border-(--color-accent) dark:hover:border-(--color-dark-accent) transition-colors"
  >
    All
  </button>
  {tags.map(tag => (
    <button
      data-tag={tag}
      class="tag-btn text-sm px-3 py-1.5 rounded-full border border-(--color-border) dark:border-(--color-dark-border) hover:border-(--color-accent) dark:hover:border-(--color-dark-accent) transition-colors"
    >
      {tag}
    </button>
  ))}
</div>

<style>
  .tag-btn.active {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }
  :global(.dark) .tag-btn.active {
    background: var(--color-dark-accent);
    border-color: var(--color-dark-accent);
  }
</style>

<script>
  function initFilters() {
    const buttons = document.querySelectorAll('.tag-btn');
    const input = document.getElementById('search-input') as HTMLInputElement | null;
    const posts = document.querySelectorAll('[data-tags]');

    let activeTag = 'all';

    function applyFilters() {
      const query = input?.value.toLowerCase() || '';

      posts.forEach(post => {
        const el = post as HTMLElement;
        const title = (el.dataset.title || '').toLowerCase();
        const tagsStr = el.dataset.tags || '';
        const tagList = tagsStr.split(',').filter(Boolean);

        const matchesTag = activeTag === 'all' || tagList.includes(activeTag);
        const matchesSearch = !query || title.includes(query) || tagsStr.toLowerCase().includes(query);

        el.style.display = matchesTag && matchesSearch ? '' : 'none';
      });
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeTag = (btn as HTMLElement).dataset.tag || 'all';
        applyFilters();
      });
    });

    input?.addEventListener('input', applyFilters);
  }
  initFilters();
  document.addEventListener('astro:after-swap', initFilters);
</script>
