---
interface NavPost {
  title: string;
  slug: string;
}

interface Props {
  prev?: NavPost;
  next?: NavPost;
}

const { prev, next } = Astro.props;
---
{(prev || next) && (
  <nav class="mt-16 pt-8 border-t border-(--color-border) dark:border-(--color-dark-border) grid grid-cols-2 gap-4">
    {prev ? (
      <a href={`/blog/${prev.slug}`} class="group text-left">
        <span class="text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">&larr; 이전 글</span>
        <p class="mt-1 font-medium group-hover:text-(--color-accent) dark:group-hover:text-(--color-dark-accent) transition-colors">
          {prev.title}
        </p>
      </a>
    ) : <div />}
    {next ? (
      <a href={`/blog/${next.slug}`} class="group text-right">
        <span class="text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">다음 글 &rarr;</span>
        <p class="mt-1 font-medium group-hover:text-(--color-accent) dark:group-hover:text-(--color-dark-accent) transition-colors">
          {next.title}
        </p>
      </a>
    ) : <div />}
  </nav>
)}
