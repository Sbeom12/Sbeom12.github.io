<div class="relative">
  <input
    id="search-input"
    type="text"
    placeholder="Search posts..."
    class="w-full px-4 py-2.5 rounded-xl border border-(--color-border) dark:border-(--color-dark-border) bg-(--color-bg-primary) dark:bg-(--color-dark-bg-primary) text-(--color-text-primary) dark:text-(--color-dark-text-primary) placeholder:text-(--color-text-secondary) dark:placeholder:text-(--color-dark-text-secondary) focus:outline-none focus:border-(--color-accent) dark:focus:border-(--color-dark-accent) transition-colors"
  />
  <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-5 h-5 text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <circle cx="11" cy="11" r="8" />
    <path d="m21 21-4.3-4.3" />
  </svg>
</div>

<script>
  function initSearch() {
    const input = document.getElementById('search-input') as HTMLInputElement;
    const posts = document.querySelectorAll('[data-title]');

    input?.addEventListener('input', () => {
      const query = input.value.toLowerCase();
      posts.forEach(post => {
        const title = (post as HTMLElement).dataset.title?.toLowerCase() || '';
        const tags = (post as HTMLElement).dataset.tags?.toLowerCase() || '';
        if (title.includes(query) || tags.includes(query)) {
          (post as HTMLElement).style.display = '';
        } else {
          (post as HTMLElement).style.display = 'none';
        }
      });
    });
  }
  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>
