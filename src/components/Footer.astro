---
const year = new Date().getFullYear();
---
<footer class="border-t border-(--color-border) dark:border-(--color-dark-border) bg-(--color-bg-secondary)/50 dark:bg-(--color-dark-bg-secondary)/50">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex flex-col items-center md:items-start gap-1">
        <p class="text-sm font-medium text-(--color-text-primary) dark:text-(--color-dark-text-primary)">
          Blog
        </p>
        <p class="text-xs text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">
          &copy; {year} Sbeom12. All rights reserved.
        </p>
      </div>
      <div class="flex items-center gap-6">
        <a
          href="https://github.com/Sbeom12"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) hover:text-(--color-accent) dark:hover:text-(--color-dark-accent) transition-colors"
        >
          GitHub
        </a>
        <span class="w-1 h-1 rounded-full bg-(--color-border) dark:bg-(--color-dark-border)"></span>
        <a
          href="/rss.xml"
          class="text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) hover:text-(--color-accent) dark:hover:text-(--color-dark-accent) transition-colors"
        >
          RSS
        </a>
      </div>
    </div>
  </div>
</footer>
