---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;
const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<article class="group">
  <a href={`/blog/${slug}`} class="block p-6 -mx-6 rounded-2xl hover:bg-(--color-bg-secondary) dark:hover:bg-(--color-dark-bg-secondary) transition-colors">
    <time class="text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">
      {formattedDate}
    </time>
    <h2 class="mt-2 text-xl font-semibold group-hover:text-(--color-accent) dark:group-hover:text-(--color-dark-accent) transition-colors">
      {title}
    </h2>
    <p class="mt-2 text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) line-clamp-2">
      {description}
    </p>
    <div class="mt-3 flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="text-xs px-2.5 py-1 rounded-full bg-(--color-bg-secondary) dark:bg-(--color-dark-bg-secondary) text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">
          {tag}
        </span>
      ))}
    </div>
  </a>
</article>
