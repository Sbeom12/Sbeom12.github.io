---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  headings: MarkdownHeading[];
  readingTime: number;
  ogImage?: string;
}

const { title, description, date, tags, headings, readingTime, ogImage } = Astro.props;
const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-3xl xl:max-w-5xl mx-auto px-6 py-16">
    <!-- Header -->
    <header class="max-w-3xl mb-8">
      <div class="flex items-center gap-3 text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) mb-4">
        <time class="tabular-nums">{formattedDate}</time>
        <span class="w-1 h-1 rounded-full bg-(--color-border) dark:bg-(--color-dark-border)"></span>
        <span>{readingTime}분 읽기</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold leading-tight">{title}</h1>
      <p class="mt-3 text-lg text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) leading-relaxed">
        {description}
      </p>
      <div class="mt-4 flex flex-wrap gap-1.5">
        {tags.map(tag => (
          <a href={`/blog?tag=${tag}`} class="text-xs px-2.5 py-1 rounded-md bg-(--color-bg-secondary) dark:bg-(--color-dark-bg-secondary) text-(--color-accent) dark:text-(--color-dark-accent) font-medium hover:bg-(--color-accent)/10 dark:hover:bg-(--color-dark-accent)/10 transition-colors">
            {tag}
          </a>
        ))}
      </div>
    </header>

    <hr class="border-(--color-border) dark:border-(--color-dark-border) mb-10" />

    <!-- Content + TOC -->
    <div class="flex">
      <article class="min-w-0 flex-1 max-w-3xl">
        <div class="prose prose-lg prose-blog max-w-none">
          <slot />
        </div>

        <slot name="post-footer" />
      </article>

      <TOC headings={headings} />
    </div>
  </div>
</BaseLayout>
