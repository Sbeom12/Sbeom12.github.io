---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  headings: MarkdownHeading[];
  readingTime: number;
  ogImage?: string;
}

const { title, description, date, tags, headings, readingTime, ogImage } = Astro.props;
const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout title={title} description={description} ogImage={ogImage}>
  <div class="max-w-5xl mx-auto px-6 py-16 flex">
    <article class="min-w-0 max-w-3xl">
      <header class="mb-10">
        <time class="text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">
          {formattedDate}
        </time>
        <span class="text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) mx-2">&middot;</span>
        <span class="text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">
          {readingTime}분 읽기
        </span>
        <h1 class="mt-3 text-4xl font-bold leading-tight">{title}</h1>
        <p class="mt-3 text-lg text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">
          {description}
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map(tag => (
            <a href={`/blog?tag=${tag}`} class="text-xs px-2.5 py-1 rounded-full bg-(--color-bg-secondary) dark:bg-(--color-dark-bg-secondary) text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) hover:text-(--color-accent) dark:hover:text-(--color-dark-accent) transition-colors">
              {tag}
            </a>
          ))}
        </div>
      </header>

      <div class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-semibold prose-a:text-(--color-accent) dark:prose-a:text-(--color-dark-accent) prose-code:before:content-none prose-code:after:content-none">
        <slot />
      </div>

      <slot name="post-footer" />
    </article>

    <TOC headings={headings} />
  </div>
</BaseLayout>
